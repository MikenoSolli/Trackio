generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model alert {
  id         String         @id
  vehicleId  String
  type       alert_type
  severity   alert_severity @default(MEDIUM)
  message    String
  isResolved Boolean        @default(false)
  createdAt  DateTime       @default(now())
  DriverId   String
  driver     driver         @relation(fields: [DriverId], references: [id], onDelete: NoAction, map: "Alert_DriverId_fkey")
  vehicle    vehicle        @relation(fields: [vehicleId], references: [id], onDelete: NoAction, map: "Alert_vehicleId_fkey")

  @@index([DriverId], map: "Alert_DriverId_fkey")
  @@index([vehicleId], map: "Alert_vehicleId_fkey")
}

model companies {
  id        Int       @id @default(autoincrement())
  name      String
  email     String?
  phone     String?
  address   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime
  driver    driver[]
  users     users[]
  vehicle   vehicle[]
}

model dailysummary {
  id              String   @id
  vehicleId       String
  date            DateTime
  modeFuelLevel   Float?
  modeOilPressure Float?
  modeBattVoltage Float?
  modeEngineLoad  Float?
  modeSpeed       Float?
  modeEngineRPM   Float?
  modeEngineTemp  Float?
  totalDistance   Float    @default(0)
  totalFuelUsed   Float    @default(0)
  totalEngineHrs  Float    @default(0)
  IdleTime        Float    @default(0)
  RunningTime     Float    @default(0)
  sampleCount     Int      @default(0)
  updatedAt       DateTime
  vehicle         vehicle  @relation(fields: [vehicleId], references: [id], onDelete: NoAction, map: "dailySummary_vehicleId_fkey")

  @@unique([vehicleId, date], map: "dailySummary_vehicleId_date_key")
  @@index([date], map: "dailySummary_date_idx")
}

model driver {
  id          String     @id
  name        String
  phone       String?
  licenseNo   String?
  performance Float      @default(100)
  licenceExp  DateTime?  @db.Date
  companyId   Int?
  alert       alert[]
  companies   companies? @relation(fields: [companyId], references: [id], onUpdate: NoAction, map: "Driver_companyId_fkey")
  vehicle     vehicle?

  @@index([companyId], map: "Driver_companyId_fkey")
}

model maintenance {
  id          String   @id
  vehicleId   String
  serviceDate DateTime
  nextService DateTime
  description String
  cost        Float?
  vehicle     vehicle  @relation(fields: [vehicleId], references: [id], onDelete: NoAction, map: "Maintenance_vehicleId_fkey")

  @@index([vehicleId], map: "Maintenance_vehicleId_fkey")
}

model maintenance_data {
  id          String   @id
  vehicleId   String
  fuelRate    Float?
  fuelEff     Float?
  EngineHours Float?
  updatedAt   DateTime @default(now())
  vehicle     vehicle  @relation(fields: [vehicleId], references: [id], onDelete: NoAction, map: "Vehicle_maintenance_data_fkey")

  @@index([vehicleId], map: "Vehicle_maintenance_data_fkey")
}

model status {
  id          String       @id
  lastLat     Float?
  lastLng     Float?
  lastSpeed   Float?       @default(0)
  state       status_state @default(OFFLINE)
  fuelLevel   Float?       @default(100)
  engineHours Float?       @default(0)
  lastUpdate  DateTime     @default(now())
  vehicleId   String
  BattVoltage Float?       @default(0)
  EngineLoad  Float?       @default(0)
  OilPressure Float?       @default(0)
  distance    Float?       @default(0)
  engineRPM   Int?         @default(2400)
  engineTemp  Float?       @default(80)
  fuelUsed    Float?       @default(0)
  vehicle     vehicle      @relation(fields: [vehicleId], references: [id], onDelete: NoAction, map: "Status_vehicleId_fkey")

  @@index([vehicleId, lastUpdate], map: "idx_status_vehicle_date")
}

model trip {
  id        String    @id
  vehicleId String
  startTime DateTime
  endTime   DateTime?
  distance  Float     @default(0)
  fuelUsed  Float     @default(0)
  startLoc  String?
  endLoc    String?
  vehicle   vehicle   @relation(fields: [vehicleId], references: [id], onDelete: NoAction, map: "Trip_vehicleId_fkey")

  @@index([vehicleId], map: "Trip_vehicleId_fkey")
}

model users {
  id           Int        @id @default(autoincrement())
  name         String?
  email        String     @unique
  password     String
  role         users_role @default(USER)
  created_data DateTime   @default(now())
  updatedAt    DateTime
  companyId    Int?
  companies    companies? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "User_companyId_fkey")
  vehicle      vehicle[]

  @@index([companyId], map: "User_companyId_fkey")
}

model vehicle {
  id               String             @id
  Type             vehicle_Type       @default(TRACTOR)
  plateNumber      String?            @unique(map: "Vehicle_plateNumber_key")
  make             String?
  model            String?
  driverId         String?            @unique(map: "Vehicle_driverId_key")
  ownerId          Int
  capacity         Int?
  companyId        Int?
  alert            alert[]
  dailysummary     dailysummary[]
  maintenance      maintenance[]
  maintenance_data maintenance_data[]
  status           status[]
  trip             trip[]
  companies        companies?         @relation(fields: [companyId], references: [id], onUpdate: NoAction, map: "Vehicle_companyId_fkey")
  driver           driver?            @relation(fields: [driverId], references: [id], map: "Vehicle_driverId_fkey")
  users            users              @relation(fields: [ownerId], references: [id], onDelete: NoAction, map: "Vehicle_ownerId_fkey")

  @@index([companyId], map: "Vehicle_companyId_fkey")
  @@index([ownerId], map: "Vehicle_ownerId_fkey")
}

enum vehicle_Type {
  TRACTOR
  TRUCK
  CAR
  BUS
  MOTORCYCLE
}

enum alert_type {
  SPEEDING
  GEOFENCE_EXIT
  LOW_FUEL
  MAINTENANCE_DUE
  FAULT
  STOP
}

enum alert_severity {
  LOW
  MEDIUM
  HIGH
}

enum status_state {
  ACTIVE
  IDLE
  OFFLINE
}

enum users_role {
  USER
  ADMIN
}
